# .env.prod.example — copy to .env.prod and fill in. NEVER commit the real .env.prod.
# Used by: docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build
# Values are documented by NAME here; real secrets live only in the gitignored .env.prod
# (or a secrets manager). See docs/DEPLOY.md.

# --- Public domain (drives ALLOWED_HOSTS, CSRF origins, TLS, OAuth redirect) -----------
# The exact host the app is served on. You chose a subdomain of a domain you own, e.g.:
CAT_DOMAIN=joc.example.ro
# ACME registration email for Caddy's Let's Encrypt certificate (Cloudflare grey-cloud).
TLS_EMAIL=you@example.ro

# --- Django secret (REQUIRED; signs session/CSRF cookies) ------------------------------
# Generate one: python -c "import secrets; print(secrets.token_urlsafe(64))"
CAT_SECRET_KEY=CHANGE_ME_generate_a_64_char_random_string

# --- Postgres ------------------------------------------------------------------------
POSTGRES_DB=cat
POSTGRES_USER=cat
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# --- Google OAuth (from Google Cloud Console → APIs & Services → Credentials) ----------
# Authorized redirect URI to register there:
#   https://${CAT_DOMAIN}/accounts/google/login/callback/
# Authorized JavaScript origin:
#   https://${CAT_DOMAIN}
GOOGLE_OAUTH_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=CHANGE_ME

# --- Optional knobs ------------------------------------------------------------------
# Bundled offline KG fixture baked into the image (default = the real-corpus build).
CAT_KG_FIXTURE=cat_de_roman_esti/fixtures/kg_real.json
# Raise to e.g. 31536000 once the domain + TLS are stable (HSTS; hard to undo — read docs).
CAT_HSTS_SECONDS=0
# Bump to force re-consent after a material privacy/ToS change.
CAT_CONSENT_VERSION=2026-07-09
