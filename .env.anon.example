# .env.anon.example — copy to .env.anon and fill in. NEVER commit the real .env.anon.
# Used by: docker compose -f docker-compose.anon.yml --env-file .env.anon up -d --build
# Values are documented by NAME here; real secrets live only in the gitignored .env.anon
# (or a secrets manager). See docs/DEPLOY.md.
#
# This is the ANONYMOUS ARCADE stack (CAT_ACCOUNTS_ENABLED=0): no Postgres, no Google
# OAuth, no PII — just this domain + TLS email.

# --- Public domain (drives ALLOWED_HOSTS, CSRF origins, TLS) ---------------------------
# The exact host the app is served on, e.g. a subdomain of a domain you own:
CAT_DOMAIN=joc.example.ro
# ACME registration email for Caddy's Let's Encrypt certificate (Cloudflare grey-cloud).
TLS_EMAIL=you@example.ro

# --- Django secret (OPTIONAL in anon mode; only enforced when accounts are on) ---------
# Generate one: python -c "import secrets; print(secrets.token_urlsafe(64))"
CAT_SECRET_KEY=

# --- Legal pages (fill BEFORE pointing real users at the site) -------------------------
# Operator identity + privacy contact shown on /legal/privacy and /legal/terms. While
# either is empty the pages keep the DRAFT "not finalized" placeholder wording.
CAT_LEGAL_OPERATOR=
CAT_LEGAL_CONTACT_EMAIL=

# --- Optional knobs ------------------------------------------------------------------
# Donations = the monetisation strategy. When set, the SPA shows a "Donează" button.
# Point it at your donation page/provider (Stripe payment link, redirecționează.ro, the
# ONG's page). Empty = button hidden.
CAT_DONATE_URL=
# Raise to e.g. 31536000 once the domain + TLS are stable (HSTS; hard to undo — read docs).
CAT_HSTS_SECONDS=0
