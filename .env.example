# RO-EDU data platform connection for cat_de_roman_esti.
# Copy to .env and adjust. The CLI reads these (env overrides built-in defaults);
# --offline ignores them and plays against the bundled fixture.

ROEDU_API_URL=http://localhost:8077
ROEDU_API_KEY=cat-de-roman-dev

# Curated games pack override (defaults to the bundled fixtures/games_pack.json).
# CAT_GAMES_PACK=cat_de_roman_esti/fixtures/games_pack.json

# User-submitted games (ADR-0011): set to a writable, persistent directory to enable
# POST /api/submissions (pending queue, reviewed via scripts/review_submissions.py).
# Unset = the endpoint answers 503 and the feature is off.
# CAT_SUBMISSIONS_DIR=/data/submissions
